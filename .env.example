# Shopify Storefront API — copy to .env.local and fill in (never commit .env.local)
# NEXT_PUBLIC_ prefix is deliberate: the Storefront token is a PUBLIC token,
# designed for client-side use. The Admin API is banned in this project.
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your-public-storefront-access-token
NEXT_PUBLIC_SHOPIFY_API_VERSION=2026-07

# PostHog (Milestone 3 — A/B experiment). Project API key is public by design.
# Leave unset to run without analytics (PostHog init becomes a no-op).
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
